<resources>
    <style name="AppTheme" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">@color/colorPrimary</item>
        <item name="colorPrimaryVariant">@color/colorPrimaryDark</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorSecondary">@color/colorAccent</item>
        <item name="colorSecondaryVariant">@color/colorSecondary</item>
        <item name="colorOnSecondary">@color/white</item>
        <item name="colorSurface">@color/surfaceCard</item>
        <item name="colorBackground">@color/surfaceBackground</item>
        <item name="android:colorBackground">@color/surfaceBackground</item>
        <item name="materialButtonStyle">@style/Widget.SKIBin.Button.Primary</item>
        <item name="materialCardViewStyle">@style/Widget.SKIBin.Card</item>
        <item name="toolbarStyle">@style/Widget.SKIBin.Toolbar</item>
    </style>

    <style name="Widget.SKIBin.Toolbar" parent="Widget.MaterialComponents.Toolbar.Primary">
        <item name="android:background">@color/colorPrimary</item>
        <item name="titleTextColor">@color/white</item>
        <item name="subtitleTextColor">@color/white</item>
        <item name="android:elevation">@dimen/toolbar_elevation</item>
    </style>

    <style name="Widget.SKIBin.Card" parent="Widget.MaterialComponents.CardView">
        <item name="cardBackgroundColor">@color/surfaceCard</item>
        <item name="cardCornerRadius">@dimen/card_radius</item>
        <item name="cardElevation">@dimen/toolbar_elevation</item>
        <item name="strokeColor">@color/strokeSubtle</item>
        <item name="strokeWidth">1dp</item>
    </style>

    <style name="Widget.SKIBin.Card.Compact" parent="Widget.SKIBin.Card">
        <item name="cardCornerRadius">@dimen/card_radius_small</item>
    </style>

    <style name="Widget.SKIBin.Button.Primary" parent="Widget.MaterialComponents.Button">
        <item name="android:textAllCaps">false</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">@color/white</item>
        <item name="backgroundTint">@color/buttonPrimary</item>
        <item name="cornerRadius">18dp</item>
        <item name="iconTint">@color/white</item>
        <item name="rippleColor">@color/buttonPrimaryPressed</item>
        <item name="insetTop">0dp</item>
        <item name="insetBottom">0dp</item>
    </style>

    <style name="Widget.SKIBin.Button.Secondary" parent="Widget.MaterialComponents.Button.OutlinedButton">
        <item name="android:textAllCaps">false</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">@color/colorPrimary</item>
        <item name="strokeColor">@color/strokeSubtle</item>
        <item name="backgroundTint">@color/surfaceCard</item>
        <item name="cornerRadius">18dp</item>
        <item name="iconTint">@color/colorPrimary</item>
        <item name="insetTop">0dp</item>
        <item name="insetBottom">0dp</item>
    </style>

    <style name="Widget.SKIBin.Button.Danger" parent="Widget.SKIBin.Button.Primary">
        <item name="backgroundTint">@color/buttonDanger</item>
    </style>
</resources>
