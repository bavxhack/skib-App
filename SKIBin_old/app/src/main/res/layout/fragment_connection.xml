<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/fragment_mitarbeiter"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/surfaceBackground"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="@dimen/default_margin">

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/card_org"
            style="@style/Widget.SKIBin.Card"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Gerät verbinden"
                    android:textColor="@color/black"
                    android:textSize="24sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="Verbinde dieses Gerät mit Organisation oder Betreuung über den QR-Code aus der Webanwendung."
                    android:textColor="@color/grey"
                    android:textSize="15sp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/scanConnection"
                    style="@style/Widget.SKIBin.Button.Primary"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:layout_marginTop="20dp"
                    android:text="@string/noSetting"
                    android:textSize="18sp"
                    app:icon="@drawable/ic_baseline_check_24"
                            app:iconGravity="textStart"
                            app:iconPadding="12dp" />

                <LinearLayout
                    android:id="@+id/user_info"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="20dp"
                    android:background="@color/surfaceMuted"
                    android:orientation="vertical"
                    android:padding="16dp"
                    android:visibility="gone">

                    <TextView
                        android:id="@+id/user_name"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textColor="@color/black"
                        android:textSize="18sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/user_organisation"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:textColor="@color/grey"
                        android:textSize="15sp" />

                    <TextView
                        android:id="@+id/user_email"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:textColor="@color/grey"
                        android:textSize="15sp" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/orgInfo"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="20dp"
                    android:background="@color/surfaceMuted"
                    android:orientation="vertical"
                    android:padding="16dp"
                    android:visibility="gone">

                    <TextView
                        android:id="@+id/org_name"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/organisationName"
                        android:textColor="@color/black"
                        android:textSize="18sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/orgPartner"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:text="@string/ansprechpartner"
                        android:textColor="@color/grey"
                        android:textSize="15sp" />

                    <TextView
                        android:id="@+id/orgId"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Organisation ID"
                        android:textColor="@color/grey"
                        android:textSize="14sp"
                        android:visibility="gone" />

                    <TextView
                        android:id="@+id/orgUrl"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Organisation Url"
                        android:textColor="@color/grey"
                        android:textSize="14sp"
                        android:visibility="gone" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/settingConnectionOrg"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:orientation="vertical">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/connectionOrgSave"
                        style="@style/Widget.SKIBin.Button.Primary"
                        android:layout_width="match_parent"
                        android:layout_height="52dp"
                        android:enabled="false"
                        android:text="@string/save"
                        android:textSize="16sp"
                        android:visibility="gone"
                        app:icon="@drawable/ic_baseline_check_24"
                            app:iconGravity="textStart"
                            app:iconPadding="12dp" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/connectionResetOrg"
                        style="@style/Widget.SKIBin.Button.Danger"
                        android:layout_width="match_parent"
                        android:layout_height="52dp"
                        android:layout_marginTop="12dp"
                        android:enabled="false"
                        android:text="@string/delete"
                        android:textSize="16sp"
                        android:visibility="gone"
                        app:icon="@drawable/ic_baseline_delete_24"
                        app:iconGravity="textStart"
                        app:iconPadding="12dp" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/settingsConnectionUser"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:orientation="vertical">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/saveUserConnection"
                        style="@style/Widget.SKIBin.Button.Primary"
                        android:layout_width="match_parent"
                        android:layout_height="52dp"
                        android:enabled="false"
                        android:text="@string/save"
                        android:textSize="16sp"
                        android:visibility="gone"
                        app:icon="@drawable/ic_baseline_check_24"
                            app:iconGravity="textStart"
                            app:iconPadding="12dp" />

                    <LinearLayout
                        android:id="@+id/userEmailCOnfirmation"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:orientation="vertical"
                        android:visibility="gone">

                        <EditText
                            android:id="@+id/edituseremailCode"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:backgroundTint="@color/colorPrimary"
                            android:ems="10"
                            android:hint="Email Confirmation Code"
                            android:inputType="textPersonName"
                            android:padding="12dp" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/buttonEmailCOnfirmation"
                            style="@style/Widget.SKIBin.Button.Secondary"
                            android:layout_width="match_parent"
                            android:layout_height="52dp"
                            android:layout_marginTop="12dp"
                            android:text="@string/OkText" />
                    </LinearLayout>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/resetUserConnection"
                        style="@style/Widget.SKIBin.Button.Danger"
                        android:layout_width="match_parent"
                        android:layout_height="52dp"
                        android:layout_marginTop="12dp"
                        android:enabled="false"
                        android:text="@string/delete"
                        android:textSize="16sp"
                        android:visibility="gone"
                        app:icon="@drawable/ic_baseline_delete_24"
                        app:iconGravity="textStart"
                        app:iconPadding="12dp" />
                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

    </LinearLayout>
</ScrollView>
